
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stored information about ANFLOCOR employees.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["employee", "manager", "admin"] }
      },
      "required": ["uid", "email"]
    },
    "CustomerMapping": {
      "title": "Customer Mapping",
      "description": "Mapping of customers to SAP production channels.",
      "type": "object",
      "properties": {
        "CustomerID": { "type": "string" },
        "Customer": { "type": "string" },
        "SAPC_Code": { "type": "string" },
        "SAPC_Desc": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["CustomerID", "Customer"]
    },
    "MaterialMapping": {
      "title": "Material Mapping",
      "description": "Mapping of materials to SAP codes with pack type details.",
      "type": "object",
      "properties": {
        "MaterialID": { "type": "string" },
        "Material": { "type": "string" },
        "KindOfPack": { "type": "string" },
        "SAPC_Code": { "type": "string" },
        "SAPC_Type": { "type": "string" },
        "SAPC_Desc": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["MaterialID", "Material"]
    },
    "Contract": {
      "title": "Production Contract",
      "description": "Contract details received from customer emails.",
      "type": "object",
      "properties": {
        "contractId": { "type": "string" },
        "contractRef": { "type": "string", "description": "Customer reference number" },
        "customerName": { "type": "string" },
        "receivedAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "active", "completed", "cancelled"] },
        "totalQuantity": { "type": "number" },
        "notes": { "type": "string" }
      },
      "required": ["contractId", "customerName", "status"]
    },
    "ContractLineItem": {
      "title": "Contract Line Item",
      "description": "Specific material and order details within a contract.",
      "type": "object",
      "properties": {
        "itemId": { "type": "string" },
        "materialCode": { "type": "string" },
        "quantity": { "type": "number" },
        "uom": { "type": "string", "description": "Unit of measure" },
        "packType": { "type": "string" },
        "specifications": { "type": "string", "description": "Specific line item orders/specs" },
        "status": { "type": "string" }
      },
      "required": ["itemId", "materialCode", "quantity"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "User profile document"
    },
    "/app_configuration/customer_mapping/customer_saving/{mappingId}": {
      "schema": { "$ref": "#/backend/entities/CustomerMapping" },
      "description": "Customer mapping records"
    },
    "/app_configuration/material_mapping/material_saving/{mappingId}": {
      "schema": { "$ref": "#/backend/entities/MaterialMapping" },
      "description": "Material mapping records"
    },
    "/app_configuration/contracts/contract_saving/{contractId}": {
      "schema": { "$ref": "#/backend/entities/Contract" },
      "description": "Root contract records"
    },
    "/app_configuration/contracts/contract_saving/{contractId}/items/{itemId}": {
      "schema": { "$ref": "#/backend/entities/ContractLineItem" },
      "description": "Individual line items for a specific contract"
    }
  }
}
