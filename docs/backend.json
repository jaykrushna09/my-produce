{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stored information about ANFLOCOR employees.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["employee", "manager", "admin"] }
      },
      "required": ["uid", "email"]
    },
    "CustomerMapping": {
      "title": "Customer Mapping",
      "description": "Mapping of customers to production channels.",
      "type": "object",
      "properties": {
        "customerCode": { "type": "string" },
        "customerName": { "type": "string" },
        "productionChannel": { "type": "string" },
        "region": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerCode", "customerName"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "User profile document"
    },
    "/customerMappings/{mappingId}": {
      "schema": { "$ref": "#/entities/CustomerMapping" },
      "description": "Customer mapping records"
    }
  }
}
