
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stored information about ANFLOCOR employees.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["employee", "manager", "admin"] }
      },
      "required": ["uid", "email"]
    },
    "CustomerMapping": {
      "title": "Customer Mapping",
      "description": "Mapping of customers to SAP production channels.",
      "type": "object",
      "properties": {
        "CustomerID": { "type": "string" },
        "Customer": { "type": "string" },
        "SAPC_Code": { "type": "string" },
        "SAPC_Desc": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["CustomerID", "Customer"]
    },
    "MaterialMapping": {
      "title": "Material Mapping",
      "description": "Mapping of materials to SAP codes with pack type details.",
      "type": "object",
      "properties": {
        "SAPC_Code": { "type": "string" },
        "KindOfPack": { "type": "string" },
        "SAPC_Type": { "type": "string" },
        "SAPC_Desc": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["SAPC_Code"]
    },
    "PortOfLoading": {
      "title": "Port of Loading",
      "description": "Mapping of origin ports.",
      "type": "object",
      "properties": {
        "portName": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["portName"]
    },
    "PortOfDestination": {
      "title": "Port of Destination",
      "description": "Mapping of destination ports.",
      "type": "object",
      "properties": {
        "portName": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["portName"]
    },
    "Contract": {
      "title": "Production Contract",
      "description": "Contract details received from customer emails.",
      "type": "object",
      "properties": {
        "contractId": { "type": "string" },
        "contractRef": { "type": "string", "description": "Customer reference number" },
        "customerName": { "type": "string" },
        "weekNumber": { "type": "string" },
        "farm": { "type": "string" },
        "pol": { "type": "string", "description": "Port of Loading" },
        "receivedAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "active", "completed", "cancelled"] },
        "notes": { "type": "string" },
        "attachmentUrl": { "type": "string" }
      },
      "required": ["contractId", "customerName", "status"]
    },
    "ContractLineItem": {
      "title": "Contract Line Item",
      "description": "Specific loading advice row from the customer.",
      "type": "object",
      "properties": {
        "itemId": { "type": "string" },
        "pod": { "type": "string", "description": "Port of Destination" },
        "total": { "type": "number" },
        "specs": { "type": "string" },
        "limitation": { "type": "string" },
        "palletized": { "type": "string", "enum": ["Palletized", "Breakbulk", "Non-Palletized"] },
        "shippingLines": { "type": "string" },
        "etd": { "type": "string" },
        "customerContractNumber": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["itemId", "pod", "total"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "User profile document"
    },
    "/app_configuration/customer_mapping/customer_saving/{mappingId}": {
      "schema": { "$ref": "#/backend/entities/CustomerMapping" },
      "description": "Customer mapping records"
    },
    "/app_configuration/material_mapping/material_saving/{mappingId}": {
      "schema": { "$ref": "#/backend/entities/MaterialMapping" },
      "description": "Material mapping records"
    },
    "/app_configuration/pol_mapping/pol_saving/{portId}": {
      "schema": { "$ref": "#/backend/entities/PortOfLoading" },
      "description": "Port of Loading records"
    },
    "/app_configuration/pod_mapping/pod_saving/{portId}": {
      "schema": { "$ref": "#/backend/entities/PortOfDestination" },
      "description": "Port of Destination records"
    },
    "/app_data/contracts/contract_saving/{contractId}": {
      "schema": { "$ref": "#/backend/entities/Contract" },
      "description": "Root contract records"
    },
    "/app_configuration/contracts/contract_saving/{contractId}/items/{itemId}": {
      "schema": { "$ref": "#/backend/entities/ContractLineItem" },
      "description": "Individual line items for a specific contract"
    }
  }
}
