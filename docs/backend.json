
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stored information about ANFLOCOR employees.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["employee", "manager", "admin"] }
      },
      "required": ["uid", "email"]
    },
    "CustomerMapping": {
      "title": "Customer Mapping",
      "description": "Mapping of customers to SAP production channels.",
      "type": "object",
      "properties": {
        "CustomerID": { "type": "string" },
        "Customer": { "type": "string" },
        "SAPC_Code": { "type": "string" },
        "SAPC_Desc": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["CustomerID", "Customer"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "User profile document"
    },
    "/app_configuration/customer_mapping/records/{mappingId}": {
      "schema": { "$ref": "#/backend/entities/CustomerMapping" },
      "description": "Customer mapping records stored in a nested structure"
    }
  }
}
